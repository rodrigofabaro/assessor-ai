# --- Database (Prisma/PostgreSQL) ---
# Local dev example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/assessor_ai?schema=public
# Optional direct connection URL (used when introducing pooled/data-proxy setups later):
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/assessor_ai?schema=public

# --- OpenAI keys (keep in .env only, never commit real values) ---
OPENAI_API_KEY=
OPENAI_ADMIN_KEY=
OPENAI_ADMIN_API_KEY=
OPENAI_ADMIN=
OPENAI_ORG_ID=

# --- OpenAI model defaults (quality-first) ---
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EQUATION_MODEL=gpt-4.1-mini
OPENAI_OCR_MODEL=gpt-4.1-mini

# --- AI provider routing (quality-first baseline) ---
# Modes: openai | local | hybrid
AI_LOCAL_ENABLED=true
AI_PROVIDER_MODE=hybrid
AI_PROVIDER_CLEANUP_MODE=local
AI_PROVIDER_OCR_MODE=openai
AI_PROVIDER_EQUATION_MODE=openai
AI_PROVIDER_GRAPH_MODE=openai

# --- Local AI server (Ollama-compatible) ---
AI_LOCAL_BASE_URL=http://127.0.0.1:11434
AI_LOCAL_TEXT_MODEL=qwen2.5:7b-instruct
AI_LOCAL_VISION_MODEL=llava:7b
AI_LOCAL_CLEANUP_MODEL=qwen2.5:7b-instruct
AI_LOCAL_OCR_MODEL=llava:7b
AI_LOCAL_EQUATION_MODEL=llava:7b
AI_LOCAL_GRAPH_MODEL=llava:7b

# --- Local provider timeouts (ms) ---
AI_LOCAL_TIMEOUT_MS=30000
AI_LOCAL_CLEANUP_TIMEOUT_MS=25000
AI_LOCAL_OCR_TIMEOUT_MS=35000
AI_LOCAL_EQUATION_TIMEOUT_MS=25000
AI_LOCAL_GRAPH_TIMEOUT_MS=30000
AI_LOCAL_BRIEF_STRUCTURE_TIMEOUT_MS=35000

# --- Extraction quality recovery ---
AI_BRIEF_STRUCTURE_RECOVERY=true
OPENAI_BRIEF_STRUCTURE_MODEL=gpt-4o-mini
OPENAI_BRIEF_STRUCTURE_MAX_OUTPUT_TOKENS=2200
OPENAI_BRIEF_STRUCTURE_TIMEOUT_MS=45000
OPENAI_BRIEF_STRUCTURE_RETRIES=1

# --- OpenAI fallback controls ---
OPENAI_GRADE_INPUT_CHAR_LIMIT=18000
OPENAI_GRADE_MAX_OUTPUT_TOKENS=1100
OPENAI_GRADE_TIMEOUT_MS=60000
OPENAI_GRADE_RETRIES=2
OPENAI_GRADE_FALLBACK_MODEL=gpt-4o
OPENAI_GRADE_PAGE_SAMPLE_COUNT=4
OPENAI_GRADE_PAGE_SAMPLE_CHAR_LIMIT=1600

OPENAI_OCR_MAX_OUTPUT_TOKENS=1200
OPENAI_OCR_TIMEOUT_MS=45000
OPENAI_OCR_RETRIES=2

OPENAI_CLEANUP_MAX_OUTPUT_TOKENS=900
OPENAI_CLEANUP_TIMEOUT_MS=30000
OPENAI_CLEANUP_RETRIES=1

OPENAI_EQ_TIMEOUT_MS=25000
OPENAI_EQ_RETRIES=1
OPENAI_GRAPH_TIMEOUT_MS=30000
OPENAI_GRAPH_RETRIES=1

# --- Grading confidence policy ---
GRADE_MODALITY_MISSING_CONFIDENCE_CAP=0.65
# Global contradiction guard: downgrade ACHIEVED when rationale language indicates evidence gaps.
GRADE_GLOBAL_CONTRADICTION_GUARD_ENABLED=true

# --- App release label ---
NEXT_PUBLIC_APP_VERSION=1.0.3
NEXT_PUBLIC_RELEASE_LABEL=maintenance

# --- Submission extraction mode (Phase 1 simplified grading) ---
# true: extract only cover pages + metadata; false: full body extraction
SUBMISSION_EXTRACT_COVER_ONLY=true
# Number of pages to inspect for cover metadata (1..3)
SUBMISSION_EXTRACT_COVER_PAGE_LIMIT=2
# Auto-start grading after extraction+triage when submission is link-complete
SUBMISSION_AUTO_GRADE_ON_EXTRACT=true
# Re-run grading when cover metadata is manually updated (refreshes personalized feedback)
SUBMISSION_AUTO_REGRADE_ON_COVER_UPDATE=true

# --- Auth rollout guards (M9 scaffold) ---
# Keep false until session/identity integration is ready.
AUTH_GUARDS_ENABLED=false
# Required for signed auth session cookie when guards are enabled.
AUTH_SESSION_SECRET=replace-with-32-char-min-secret
# Login credentials used by /login when guards are enabled.
AUTH_LOGIN_USERNAME=admin
AUTH_LOGIN_PASSWORD=change-me
# Optional role for issued session: ADMIN | ASSESSOR | IV (default ADMIN).
AUTH_LOGIN_ROLE=ADMIN
# Optional legacy bootstrap mode for non-production demos (default false).
AUTH_BOOTSTRAP_ENABLED=false
# Invite email delivery for generated credentials (none | resend).
AUTH_INVITE_EMAIL_PROVIDER=none
# Public origin used in auth emails (password recovery links).
AUTH_APP_ORIGIN=http://localhost:3000
# Password recovery token pepper (required when provider is resend).
RESET_TOKEN_PEPPER=
# Password recovery link lifetime in minutes (5..60).
AUTH_PASSWORD_RECOVERY_TTL_MINUTES=15
# Require password-recovery email delivery contract in release gate (false | true).
AUTH_REQUIRE_RECOVERY_EMAIL=false
# Optional: enable invite email checkbox by default in Admin Users.
AUTH_INVITE_EMAIL_DEFAULT_ON=false
# Required when AUTH_INVITE_EMAIL_PROVIDER=resend
RESEND_API_KEY=
AUTH_EMAIL_FROM=
# Optional contact-form sender override (falls back to AUTH_EMAIL_FROM)
CONTACT_EMAIL_FROM=
# Optional landing-page contact inbox recipient (defaults to contact@assessor-ai.co.uk)
CONTACT_FORM_TO=
# Optional operational alert sender override (falls back to AUTH_EMAIL_FROM)
ALERT_EMAIL_FROM=
# Optional operational alert inbox recipient (disabled when empty)
ALERT_EMAIL_TO=
# Resend webhook signing secret (recommended when provider is resend)
RESEND_WEBHOOK_SECRET=
# Local/dev-only webhook bypass. Keep false in production.
RESEND_WEBHOOK_ALLOW_UNSIGNED=false
# Require signed webhook config in release gate when using resend lifecycle telemetry.
AUTH_REQUIRE_EMAIL_WEBHOOK=false
# Require alert-channel configuration (`ALERT_EMAIL_TO` + sender + provider) for ops alert smoke.
AUTH_REQUIRE_ALERT_EMAIL=false
# Optional override for webhook smoke target URL.
EMAIL_WEBHOOK_SMOKE_BASE_URL=
# Require DB schema contract checks in release/cutover gate.
AUTH_REQUIRE_SCHEMA_CONTRACT=false
# Require OpenAI Responses API write-scope check in release/cutover gate.
AUTH_REQUIRE_OPENAI_RESPONSES_WRITE=false
# Enable live Responses API write probe in non-strict runs.
OPENAI_RESPONSES_WRITE_PROBE_ENABLED=false
# Optional model override used by responses contract probe.
OPENAI_RESPONSES_CONTRACT_MODEL=

# --- Storage root override (deployment migration helper) ---
# Storage backend: filesystem | vercel_blob
STORAGE_BACKEND=filesystem
# Required when STORAGE_BACKEND=vercel_blob
BLOB_READ_WRITE_TOKEN=
# Require explicit durable storage root in deploy/cutover environments.
# When true, release gate fails unless FILE_STORAGE_ROOT is set to an absolute non-temp path.
ENV_CONTRACT_REQUIRE_STORAGE_ROOT=false
# Optional: when set, relative storage paths (uploads/reference_uploads/storage/*) are resolved under this root.
# Keep empty for default local repo-root behavior.
FILE_STORAGE_ROOT=
